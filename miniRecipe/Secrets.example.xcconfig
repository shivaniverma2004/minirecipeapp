// Copy to Secrets.xcconfig and fill in YOUR values.
// Never use https:// on one line — the // starts an xcconfig comment. Use PART1 + PART2:

SUPABASE_URL_PART1 = https:/
SUPABASE_URL_PART2 = /YOUR_PROJECT_REF.supabase.co
SUPABASE_URL = $(SUPABASE_URL_PART1)$(SUPABASE_URL_PART2)

SUPABASE_ANON_KEY = your_anon_key_here

INFOPLIST_KEY_SUPABASE_URL = $(SUPABASE_URL)
INFOPLIST_KEY_SUPABASE_ANON_KEY = $(SUPABASE_ANON_KEY)
